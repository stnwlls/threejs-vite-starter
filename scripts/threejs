#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  printf '%s\n' "Usage: threejs"
  printf '%s\n' "Scaffold a minimal Vite + Three.js project in the current directory."
  printf '\n%s\n' "Requirements:"
  printf '  %s\n' "Node.js and npm must be installed. npm ships with Node.js."
  printf '  %s\n' "Node.js downloads: https://nodejs.org/en/download"
  printf '  %s\n' "npm install docs: https://docs.npmjs.com/downloading-and-installing-node-js-and-npm"
  printf '\n%s\n' "Vite:"
  printf '  %s\n' "This command installs Vite locally; no global Vite install is required."
  printf '  %s\n' "Vite docs: https://vite.dev/guide/"
  exit 0
fi

if [[ "$#" -gt 0 ]]; then
  printf '%s\n' "threejs runs in the current directory and does not accept arguments." >&2
  printf '%s\n' "Usage: threejs" >&2
  exit 1
fi

if ! command -v node >/dev/null 2>&1; then
  printf '%s\n' "node is required but was not found." >&2
  printf '%s\n' "Solution: install Node.js, then restart your terminal and run threejs again." >&2
  printf '%s\n' "Download Node.js: https://nodejs.org/en/download" >&2
  printf '%s\n' "Node/npm install docs: https://docs.npmjs.com/downloading-and-installing-node-js-and-npm" >&2
  exit 1
fi

if ! command -v npm >/dev/null 2>&1; then
  printf '%s\n' "npm is required but was not found." >&2
  printf '%s\n' "Solution: install npm, or reinstall Node.js which usually includes npm." >&2
  printf '%s\n' "npm install docs: https://docs.npmjs.com/downloading-and-installing-node-js-and-npm" >&2
  printf '%s\n' "Node.js downloads: https://nodejs.org/en/download" >&2
  exit 1
fi

conflicts=()

for path in package.json package-lock.json .gitignore index.html src/app.js src/style.css public/textures/.gitkeep; do
  if [[ -e "$path" ]]; then
    conflicts+=("$path")
  fi
done

for path in src public public/textures; do
  if [[ -e "$path" && ! -d "$path" ]]; then
    conflicts+=("$path")
  fi
done

if [[ "${#conflicts[@]}" -gt 0 ]]; then
  printf '%s\n' "threejs would overwrite or conflict with existing paths:" >&2
  for path in "${conflicts[@]}"; do
    printf '  %s\n' "$path" >&2
  done
  exit 1
fi

project_name="$(
  node -e "const path = require('path'); const name = path.basename(process.cwd()).toLowerCase().replace(/[^a-z0-9._-]/g, '-').replace(/^[._-]+|[._-]+$/g, '') || 'threejs-app'; process.stdout.write(name);"
)"

mkdir -p src public/textures
: > public/textures/.gitkeep

cat > package.json <<JSON
{
  "name": "$project_name",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  }
}
JSON

cat > .gitignore <<'GITIGNORE'
# dependencies
node_modules

# production builds
dist
dist-ssr

# local env files
.env
.env.*
!.env.example

# logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# editor and OS files
.DS_Store
.idea
.vscode/*
!.vscode/extensions.json
GITIGNORE

cat > index.html <<'HTML'
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Three.js App</title>
  </head>
  <body>
    <canvas id="app"></canvas>
    <script type="module" src="/src/app.js"></script>
  </body>
</html>
HTML

cat > src/app.js <<'JS'
import * as THREE from 'three'
import { OrbitControls } from 'three/addons/controls/OrbitControls.js'
import { GUI } from 'three/addons/libs/lil-gui.module.min.js'
import './style.css'

/**
 * Debug
 */
const gui = new GUI()

/**
 * Canvas
 */
const canvas = document.querySelector('#app')

/**
 * Scene
 */
const scene = new THREE.Scene()

/**
 * Textures
 */
const textureLoader = new THREE.TextureLoader()

/**
 * Camera
 */
const camera = new THREE.PerspectiveCamera(
  75,
  window.innerWidth / window.innerHeight,
  0.1,
  1000,
)

camera.position.z = 5
scene.add(camera)

/**
 * Renderer
 */
const renderer = new THREE.WebGLRenderer({
  canvas: canvas,
  antialias: true,
})

renderer.outputColorSpace = THREE.SRGBColorSpace
renderer.setSize(window.innerWidth, window.innerHeight)
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2))

/**
 * Controls
 */
const controls = new OrbitControls(camera, canvas)
controls.enableDamping = true

/**
 * Resize
 */
window.addEventListener('resize', () => {
  camera.aspect = window.innerWidth / window.innerHeight
  camera.updateProjectionMatrix()

  renderer.setSize(window.innerWidth, window.innerHeight)
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2))
})

/**
 * Animate
 */
const timer = new THREE.Timer()
timer.connect(document)

const animate = (timestamp) => {
  timer.update(timestamp)
  const deltaTime = timer.getDelta()

  controls.update(deltaTime)

  renderer.render(scene, camera)
  requestAnimationFrame(animate)
}

animate()
JS

cat > src/style.css <<'CSS'
*,
*::before,
*::after {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  height: 100%;
}

body {
  overflow: hidden;
}

#app {
  width: 100%;
  height: 100%;
  display: block;
}
CSS

if ! npm install three; then
  printf '%s\n' "Failed to install three." >&2
  printf '%s\n' "Solution: check your internet connection and npm setup, then run npm install three manually." >&2
  printf '%s\n' "npm docs: https://docs.npmjs.com/downloading-and-installing-node-js-and-npm" >&2
  exit 1
fi

if ! npm install --save-dev vite; then
  printf '%s\n' "Failed to install Vite." >&2
  printf '%s\n' "Solution: check your internet connection and npm setup, then run npm install --save-dev vite manually." >&2
  printf '%s\n' "Vite docs: https://vite.dev/guide/" >&2
  exit 1
fi

printf '\n%s\n' "Three.js project ready."
printf '%s\n' "Run: npm run dev"
